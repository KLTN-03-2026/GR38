// ============================================================
// AI History Learning - Database Schema (MongoDB + Mongoose)
// Tạo từ source code: backend/models/
// Dùng để import vào dbdiagram.io
// ============================================================

// ========================
// MODULE 1: Quản lý người dùng
// ========================

Table users {
  _id ObjectId [pk, note: 'Khóa chính - MongoDB ObjectId']
  fullName String [not null, note: 'Họ tên (min 3 ký tự)']
  email String [not null, unique, note: 'Email đăng nhập (lowercase)']
  password String [note: 'Mật khẩu mã hóa bcrypt (bắt buộc khi authType=local)']
  role String [not null, default: 'LEARNER', note: 'Vai trò: ADMIN | TEACHER | LEARNER']
  teacherApprovalStatus String [default: 'pending', note: 'Trạng thái duyệt GV: pending | approved | rejected']
  isActive Boolean [not null, default: true, note: 'Trạng thái hoạt động']
  profileImage String [note: 'URL ảnh đại diện (Cloudinary)']
  currentStreak Number [default: 0, note: 'Chuỗi ngày học liên tiếp']
  lastStudyDate Date [note: 'Ngày học gần nhất']
  googleId String [note: 'Google OAuth ID']
  authType String [not null, default: 'local', note: 'Loại xác thực: local | google']
  resetPasswordOtp String [note: 'Mã OTP đặt lại mật khẩu']
  resetPasswordOtpExpires Date [note: 'Thời hạn OTP']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (role, teacherApprovalStatus, isActive) [name: 'idx_role_status_active']
  }

  Note: 'Lưu trữ thông tin người dùng (Admin, Giáo viên, Học sinh). Hỗ trợ đăng nhập local và Google OAuth.'
}

// ========================
// MODULE 2: Quản lý tài liệu
// ========================

Table documents {
  _id ObjectId [pk, note: 'Khóa chính']
  userId ObjectId [not null, ref: > users._id, note: 'Người tải lên (Teacher)']
  title String [not null, note: 'Tiêu đề tài liệu']
  thumbnail String [note: 'URL ảnh thumbnail']
  fileName String [not null, note: 'Tên file gốc']
  filePath String [not null, note: 'Đường dẫn file trên cloud']
  localPath String [note: 'Đường dẫn file trên server']
  fileSize Number [not null, note: 'Kích thước file (bytes)']
  extractedText String [default: '', note: 'Nội dung text trích xuất từ PDF']
  lastAccessed Date [note: 'Lần truy cập gần nhất']
  status String [not null, default: 'processing', note: 'Trạng thái: processing | ready | failed']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (userId, createdAt) [name: 'idx_user_created']
  }

  Note: 'Lưu trữ tài liệu PDF do giáo viên tải lên. Hỗ trợ trích xuất text và chia chunks phục vụ AI.'
}

Table document_chunks {
  _id ObjectId [pk, note: 'Khóa chính (embedded trong documents)']
  document_id ObjectId [not null, ref: > documents._id, note: 'Tài liệu chứa chunk']
  content String [not null, note: 'Nội dung chunk text']
  pageNumber Number [default: 0, note: 'Số trang chứa chunk']
  chunkIndex Number [not null, note: 'Thứ tự chunk']

  Note: 'Sub-document embedded trong Documents. Lưu trữ các phần text đã chia nhỏ từ tài liệu PDF phục vụ RAG.'
}

// ========================
// MODULE 3: Flashcard
// ========================

Table flashcards {
  _id ObjectId [pk, note: 'Khóa chính']
  documentId ObjectId [ref: > documents._id, note: 'Tài liệu nguồn (nullable)']
  teacherId ObjectId [not null, ref: > users._id, note: 'Giáo viên tạo bộ thẻ']
  title String [not null, note: 'Tiêu đề bộ thẻ']
  thumbnail String [note: 'URL ảnh thumbnail']
  description String [default: '', note: 'Mô tả bộ thẻ']
  isAiGenerated Boolean [not null, default: false, note: 'AI tạo tự động hay không']
  isPublished Boolean [not null, default: false, note: 'Trạng thái xuất bản']
  tags "String[]" [note: 'Danh sách nhãn/tag']
  stats_enrolledLearners Number [default: 0, note: 'Số học sinh đã đăng ký']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (teacherId, createdAt) [name: 'idx_teacher_created']
    (teacherId, isPublished) [name: 'idx_teacher_published']
  }

  Note: 'Lưu trữ bộ thẻ ghi nhớ (Flashcard Set). Giáo viên tạo thủ công hoặc AI tạo tự động từ tài liệu.'
}

Table flashcard_cards {
  _id ObjectId [pk, note: 'Khóa chính (embedded trong flashcards)']
  flashcard_set_id ObjectId [not null, ref: > flashcards._id, note: 'Bộ thẻ chứa']
  front String [not null, note: 'Mặt trước: câu hỏi/thuật ngữ']
  back String [not null, note: 'Mặt sau: đáp án/giải thích']
  difficulty String [not null, default: 'Trung bình', note: 'Độ khó: Dễ | Trung bình | Khó']

  Note: 'Sub-document embedded trong Flashcards. Lưu nội dung từng thẻ ghi nhớ.'
}

Table flashcard_progress {
  _id ObjectId [pk, note: 'Khóa chính']
  userId ObjectId [not null, ref: > users._id, note: 'Học sinh ôn tập']
  flashcardSetId ObjectId [not null, ref: > flashcards._id, note: 'Bộ thẻ đang ôn']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (userId, flashcardSetId) [unique, name: 'idx_user_set_unique']
  }

  Note: 'Theo dõi tiến độ ôn tập flashcard của từng học sinh. Mỗi học sinh chỉ có 1 bản ghi/bộ thẻ.'
}

Table flashcard_card_progress {
  _id ObjectId [pk, note: 'Khóa chính (embedded trong flashcard_progress)']
  progress_id ObjectId [not null, ref: > flashcard_progress._id, note: 'Bản ghi tiến độ chứa']
  cardId ObjectId [not null, note: 'ID thẻ ghi nhớ']
  isStarred Boolean [default: false, note: 'Đánh dấu sao (yêu thích)']
  reviewCount Number [default: 0, note: 'Số lần ôn tập']
  lastReviewed Date [note: 'Lần ôn tập gần nhất']
  nextReviewDate Date [note: 'Ngày ôn tập tiếp theo (Spaced Repetition)']
  memoryStatus String [not null, default: 'Chưa học', note: 'Trạng thái nhớ: Chưa học | Đang học | Đã nhớ']

  Note: 'Sub-document embedded trong FlashcardProgress. Theo dõi trạng thái từng thẻ của học sinh.'
}

// ========================
// MODULE 4: Quiz (Bài kiểm tra)
// ========================

Table quizzes {
  _id ObjectId [pk, note: 'Khóa chính']
  documentId ObjectId [ref: > documents._id, note: 'Tài liệu nguồn (nullable)']
  teacherId ObjectId [not null, ref: > users._id, note: 'Giáo viên tạo bài kiểm tra']
  title String [not null, note: 'Tiêu đề bài kiểm tra']
  description String [default: '', note: 'Mô tả bài kiểm tra']
  thumbnail String [note: 'URL ảnh thumbnail']
  timeLimit Number [not null, default: 30, note: 'Thời gian giới hạn (phút)']
  isAiGenerated Boolean [not null, default: false, note: 'AI tạo tự động hay không']
  totalQuestions Number [default: 0, note: 'Tổng số câu hỏi (auto tính)']
  isPublished Boolean [not null, default: false, note: 'Trạng thái xuất bản']
  tags "String[]" [note: 'Danh sách nhãn/tag']
  stats_enrolledLearners Number [default: 0, note: 'Số học sinh đã đăng ký']
  stats_totalAttempts Number [default: 0, note: 'Tổng số lượt làm bài']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (teacherId, createdAt) [name: 'idx_teacher_created']
    (teacherId, isPublished) [name: 'idx_teacher_published']
  }

  Note: 'Lưu trữ bài kiểm tra trắc nghiệm. Giáo viên tạo thủ công hoặc AI hỗ trợ tạo từ tài liệu. Tối thiểu 5 câu hỏi.'
}

Table quiz_questions {
  _id ObjectId [pk, note: 'Khóa chính (embedded trong quizzes)']
  quiz_id ObjectId [not null, ref: > quizzes._id, note: 'Bài kiểm tra chứa']
  question String [not null, note: 'Nội dung câu hỏi']
  options "String[4]" [not null, note: 'Bắt buộc đúng 4 lựa chọn']
  correctAnswer String [not null, note: 'Đáp án đúng (phải nằm trong options)']
  explanation String [default: '', note: 'Giải thích đáp án']
  difficulty String [not null, default: 'Trung bình', note: 'Độ khó: Dễ | Trung bình | Khó']

  Note: 'Sub-document embedded trong Quizzes. Lưu từng câu hỏi trắc nghiệm với 4 lựa chọn.'
}

Table quiz_results {
  _id ObjectId [pk, note: 'Khóa chính']
  userId ObjectId [not null, ref: > users._id, note: 'Học sinh làm bài']
  quizId ObjectId [not null, ref: > quizzes._id, note: 'Bài kiểm tra']
  score Number [not null, note: 'Điểm số (0-10)']
  correctAnswersCount Number [not null, note: 'Số câu trả lời đúng']
  totalQuestions Number [not null, note: 'Tổng số câu hỏi']
  timeSpent Number [default: 0, note: 'Thời gian làm bài (giây)']
  isTeacherPreview Boolean [default: false, note: 'Giáo viên xem trước (không tính thống kê)']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (userId, quizId, createdAt) [name: 'idx_user_quiz_created']
    (userId, createdAt) [name: 'idx_user_created']
    (quizId, isTeacherPreview, score) [name: 'idx_quiz_preview_score']
  }

  Note: 'Lưu trữ kết quả mỗi lần làm bài kiểm tra. Hỗ trợ thống kê và theo dõi tiến độ học sinh.'
}

Table quiz_result_answers {
  _id ObjectId [pk, note: 'Khóa chính (embedded trong quiz_results)']
  result_id ObjectId [not null, ref: > quiz_results._id, note: 'Kết quả chứa']
  questionId ObjectId [not null, note: 'ID câu hỏi']
  selectedAnswer String [note: 'Đáp án đã chọn']
  isCorrect Boolean [default: false, note: 'Trả lời đúng hay sai']

  Note: 'Sub-document embedded trong QuizResults. Lưu chi tiết từng câu trả lời của học sinh.'
}

// ========================
// MODULE 5: AI Chat
// ========================

Table chat_histories {
  _id ObjectId [pk, note: 'Khóa chính']
  userId ObjectId [not null, ref: > users._id, note: 'Người dùng chat']
  documentId ObjectId [not null, ref: > documents._id, note: 'Tài liệu liên quan']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (userId, documentId) [unique, name: 'idx_user_doc_unique']
  }

  Note: 'Lưu lịch sử hội thoại giữa người dùng và trợ lý AI về tài liệu. Mỗi user+document chỉ có 1 phiên chat.'
}

Table chat_messages {
  _id ObjectId [pk, note: 'Khóa chính (embedded trong chat_histories)']
  chat_id ObjectId [not null, ref: > chat_histories._id, note: 'Phiên chat chứa']
  role String [not null, note: 'Vai trò: user | assistant']
  content String [not null, note: 'Nội dung tin nhắn']
  timestamp DateTime [note: 'Thời điểm gửi']
  relevantChunks "Number[]" [note: 'Chỉ số chunks liên quan (RAG)']

  Note: 'Sub-document embedded trong ChatHistories. Lưu từng tin nhắn trong cuộc hội thoại AI.'
}

// ========================
// MODULE 6: Quản lý khóa học (Enrollment)
// ========================

Table courses {
  _id ObjectId [pk, note: 'Khóa chính']
  learnerId ObjectId [not null, ref: > users._id, note: 'Học sinh đăng ký']
  teacherId ObjectId [not null, ref: > users._id, note: 'Giáo viên sở hữu nội dung']
  lessonType String [not null, note: 'Loại bài học: Quiz | Flashcard']
  lessonId ObjectId [not null, note: 'ID bài học (refPath → Quiz hoặc Flashcard)']
  status String [not null, default: 'active', note: 'Trạng thái: active | completed | dropped']
  progressPercent Number [not null, default: 0, note: 'Tiến độ hoàn thành (0-100%)']
  enrolledAt Date [note: 'Thời điểm đăng ký']
  lastAccessedAt Date [note: 'Lần truy cập gần nhất']
  completedAt Date [note: 'Thời điểm hoàn thành']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (learnerId, lessonType, lessonId) [unique, name: 'idx_learner_lesson_unique']
    (teacherId, lessonType, status) [name: 'idx_teacher_type_status']
    (teacherId, learnerId) [name: 'idx_teacher_learner']
  }

  Note: 'Quản lý việc đăng ký khóa học của học sinh. Liên kết đa hình (polymorphic) đến Quiz hoặc Flashcard.'
}

// Dynamic ref cho courses.lessonId
Ref: courses.lessonId > quizzes._id
Ref: courses.lessonId > flashcards._id

// ========================
// MODULE 7: Báo cáo / Report
// ========================

Table reports {
  _id ObjectId [pk, note: 'Khóa chính']
  reporterId ObjectId [not null, ref: > users._id, note: 'Người gửi báo cáo']
  targetType String [not null, note: 'Loại đối tượng: Document | Quiz | Flashcard | User']
  targetId ObjectId [not null, note: 'ID đối tượng bị báo cáo (refPath → targetType)']
  issueType String [not null, note: 'Loại lỗi: historical_fact | timeline | inappropriate_behavior | spam | typo | other']
  description String [not null, note: 'Mô tả chi tiết lỗi']
  aiSuggestion String [note: 'Gợi ý xử lý từ AI']
  status String [not null, default: 'pending', note: 'Trạng thái: pending | resolved | rejected']
  adminNotes String [default: '', note: 'Ghi chú của Admin']
  resolvedBy ObjectId [ref: > users._id, note: 'Admin đã xử lý']
  resolvedAt Date [note: 'Thời điểm xử lý']
  createdAt DateTime [not null, note: 'Thời điểm tạo (auto)']
  updatedAt DateTime [not null, note: 'Thời điểm cập nhật (auto)']

  indexes {
    (status, createdAt) [name: 'idx_status_created']
    (targetType, targetId, status) [name: 'idx_target_status']
    (reporterId, createdAt) [name: 'idx_reporter_created']
  }

  Note: 'Lưu báo cáo lỗi từ học sinh. Hỗ trợ báo cáo đa hình (Document, Quiz, Flashcard, User). Admin xử lý.'
}

// Dynamic ref cho reports.targetId
Ref: reports.targetId > documents._id
Ref: reports.targetId > quizzes._id
Ref: reports.targetId > flashcards._id
Ref: reports.targetId > users._id

// ============================================================
// TỔNG KẾT QUAN HỆ (RELATIONSHIP SUMMARY)
// ============================================================
// users         1 ──* documents              (Teacher uploads documents)
// users         1 ──* flashcards             (Teacher creates flashcard sets)
// users         1 ──* quizzes                (Teacher creates quizzes)
// users         1 ──* quiz_results           (Student attempts quizzes)
// users         1 ──* flashcard_progress     (Student reviews flashcards)
// users         1 ──* chat_histories         (User chats with AI)
// users         1 ──* courses                (Learner enrolls / Teacher owns)
// users         1 ──* reports                (Reporter / Resolver)
// documents     1 ──* document_chunks        (Embedded sub-documents)
// documents     1 ──* flashcards             (Source document)
// documents     1 ──* quizzes                (Source document)
// documents     1 ──* chat_histories         (Chat about document)
// flashcards    1 ──* flashcard_cards        (Embedded cards)
// flashcards    1 ──* flashcard_progress     (Student progress)
// quizzes       1 ──* quiz_questions         (Embedded questions)
// quizzes       1 ──* quiz_results           (Student results)
// quiz_results  1 ──* quiz_result_answers    (Embedded answers)
// chat_histories 1──* chat_messages          (Embedded messages)
// flashcard_progress 1──* flashcard_card_progress (Embedded card progress)
// ============================================================
